generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskPriority {
  IMPORTANT
  BASIC
}

enum TaskStatus {
  PENDING
  COMPLETED
  DELETED
}

model Task {
  id          String       @id @default(uuid())

  taskName    String
  description String

  priority    TaskPriority @default(BASIC)
  status      TaskStatus   @default(PENDING)

  dueDate     DateTime?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tasks")
} 

model Circular {
  id                String   @id @default(uuid())
  circularTitle     String
  circularDescription String
  circularPostDate  DateTime
  
  circularPostTime  String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("circulars")
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  phone     String?

  otpCode   String?
  otpExpiry DateTime?

  refreshToken String?

  attendances         Attendance[]
  attendanceRequests  AttendanceRequest[]
  expenses            Expense[]
  advanceRequests     AdvanceSalaryRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id            Int      @id @default(autoincrement())

  employeeId    Int
  employee      Employee @relation(fields: [employeeId], references: [id])

  attendanceDate DateTime

  firstPunchIn  DateTime?
  lastPunchOut  DateTime?

  totalMinutes  Int      @default(0)

  status        AttendanceStatus @default(PRESENT)

  sessions      AttendanceSession[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([employeeId, attendanceDate])
}

model AttendanceSession {
  id             Int @id @default(autoincrement())

  attendanceId   Int
  attendance     Attendance @relation(fields: [attendanceId], references: [id])

  punchIn        DateTime
  punchOut       DateTime?

  durationMinute Int @default(0)

  createdAt      DateTime @default(now())
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
}

enum AttendanceRequestStatus {
  PENDING
  APPROVED
  DECLINED
}

enum AttendanceRequestType {
  PUNCH_IN_ADJUSTMENT
  PUNCH_OUT_ADJUSTMENT
  FULL_DAY_PRESENT
  HALF_DAY_PRESENT
  WORK_FROM_HOME
  OTHER
}

model AttendanceRequest {
  id          Int                      @id @default(autoincrement())

  employeeId  Int
  employee    Employee                 @relation(fields: [employeeId], references: [id])

  date        DateTime

  type        AttendanceRequestType
  reason      String

  status      AttendanceRequestStatus  @default(PENDING)

  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@map("attendance_requests")
}

// ─── Expense ─────────────────────────────────────────────────────────────────

enum ExpenseStatus {
  PENDING
  PAID
  UNPAID
  REJECTED
}

enum ExpenseType {
  AMOUNT_WISE
  UNIT_WISE
}

model Expense {
  id                 Int           @id @default(autoincrement())
  expenseCode        String        @unique  // e.g. EXP4177

  employeeId         Int
  employee           Employee      @relation(fields: [employeeId], references: [id])

  title              String
  date               DateTime
  siteName           String

  amount             Decimal       @db.Decimal(10, 2)

  category           String
  expenseType        ExpenseType   @default(AMOUNT_WISE)

  unit               String?
  unitRate           Decimal?      @db.Decimal(10, 2)

  multiLevelApproval String?

  status             ExpenseStatus @default(PENDING)

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("expenses")
}

// ─── Advance Salary ───────────────────────────────────────────────────────────

enum AdvanceSalaryStatus {
  PENDING
  APPROVED
  DECLINED
}

model AdvanceSalaryRequest {
  id             Int                  @id @default(autoincrement())

  employeeId     Int
  employee       Employee             @relation(fields: [employeeId], references: [id])

  salaryMonth    String               // e.g. "2025-08"
  amount         Decimal              @db.Decimal(10, 2)
  remark         String

  status         AdvanceSalaryStatus  @default(PENDING)
  declinedReason String?
  resolvedAt     DateTime?

  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@map("advance_salary_requests")
}
