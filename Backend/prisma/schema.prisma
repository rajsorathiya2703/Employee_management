generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TaskPriority {
  IMPORTANT
  BASIC
}

enum TaskStatus {
  PENDING
  COMPLETED
  DELETED
}

model Task {
  id          String       @id @default(uuid())

  taskName    String
  description String

  priority    TaskPriority @default(BASIC)
  status      TaskStatus   @default(PENDING)

  dueDate     DateTime?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tasks")
} 

model Circular {
  id                String   @id @default(uuid())
  circularTitle     String
  circularDescription String
  circularPostDate  DateTime
  
  circularPostTime  String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("circulars")
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  phone     String?

  // Profile fields
  firstName       String?
  lastName        String?
  personalEmail   String?
  designation     String?
  department      String?
  branch          String?
  dateOfJoining   DateTime?
  profilePhoto    String?

  otpCode   String?
  otpExpiry DateTime?

  refreshToken String? @db.Text

  attendances         Attendance[]
  attendanceRequests  AttendanceRequest[]
  expenses            Expense[]
  advanceRequests     AdvanceSalaryRequest[]
  salarySlips         SalarySlip[]
  visitsOwned         Visit[]  @relation("VisitOwner")
  visitsAsCompanion   Visit[]  @relation("VisitCompanion")
  visitsCreated       Visit[]  @relation("VisitCreatedBy")
  loanRequests        LoanRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id            Int      @id @default(autoincrement())

  employeeId    Int
  employee      Employee @relation(fields: [employeeId], references: [id])

  attendanceDate DateTime

  firstPunchIn  DateTime?
  lastPunchOut  DateTime?

  totalMinutes  Int      @default(0)

  status        AttendanceStatus @default(PRESENT)

  sessions      AttendanceSession[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([employeeId, attendanceDate])
}

model AttendanceSession {
  id             Int @id @default(autoincrement())

  attendanceId   Int
  attendance     Attendance @relation(fields: [attendanceId], references: [id])

  punchIn        DateTime
  punchOut       DateTime?

  durationMinute Int @default(0)

  createdAt      DateTime @default(now())
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
}

enum AttendanceRequestStatus {
  PENDING
  APPROVED
  DECLINED
}

enum AttendanceRequestType {
  PUNCH_IN_ADJUSTMENT
  PUNCH_OUT_ADJUSTMENT
  FULL_DAY_PRESENT
  HALF_DAY_PRESENT
  WORK_FROM_HOME
  OTHER
}

model AttendanceRequest {
  id          Int                      @id @default(autoincrement())

  employeeId  Int
  employee    Employee                 @relation(fields: [employeeId], references: [id])

  date        DateTime

  type        AttendanceRequestType
  reason      String

  status      AttendanceRequestStatus  @default(PENDING)

  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@map("attendance_requests")
}

// ─── Expense ─────────────────────────────────────────────────────────────────

enum ExpenseStatus {
  PENDING
  PAID
  UNPAID
  REJECTED
}

enum ExpenseType {
  AMOUNT_WISE
  UNIT_WISE
}

model Expense {
  id                 Int           @id @default(autoincrement())
  expenseCode        String        @unique  // e.g. EXP4177

  employeeId         Int
  employee           Employee      @relation(fields: [employeeId], references: [id])

  title              String
  date               DateTime
  siteName           String

  amount             Decimal

  category           String
  expenseType        ExpenseType   @default(AMOUNT_WISE)

  unit               String?
  unitRate           Decimal?

  multiLevelApproval String?

  status             ExpenseStatus @default(PENDING)

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("expenses")
}

// ─── Advance Salary ───────────────────────────────────────────────────────────

enum AdvanceSalaryStatus {
  PENDING
  APPROVED
  DECLINED
}

model AdvanceSalaryRequest {
  id             Int                  @id @default(autoincrement())

  employeeId     Int
  employee       Employee             @relation(fields: [employeeId], references: [id])

  salaryMonth    String               // e.g. "2025-08"
  amount         Decimal
  remark         String

  status         AdvanceSalaryStatus  @default(PENDING)
  declinedReason String?
  resolvedAt     DateTime?

  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@map("advance_salary_requests")
}

// ─── Salary Slip ──────────────────────────────────────────────────────────────

model SalarySlip {
  id             Int      @id @default(autoincrement())

  employeeId     Int
  employee       Employee @relation(fields: [employeeId], references: [id])

  // e.g. "2025-04"
  salaryMonth    String

  // Employee info snapshot
  department     String   @default("")
  designation    String   @default("")
  bankName       String   @default("")
  accountNo      String   @default("")
  panNo          String   @default("")
  salaryMode     String   @default("Bank Transfer")

  // Attendance snapshot
  monthWorkingDays Int    @default(0)
  presentDays      Int    @default(0)
  paidLeaves       Float  @default(0)
  unpaidLeaves     Float  @default(0)
  joiningGrossSalary Decimal @default(0)

  // Earnings (stored as JSON array: [{heading, amount}])
  earnings       Json     @default("[]")

  // Deductions (stored as JSON array: [{heading, amount}])
  deductions     Json     @default("[]")

  // Computed totals
  grossSalary    Decimal  @default(0)
  totalDeductions Decimal @default(0)
  netPay         Decimal  @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([employeeId, salaryMonth])
  @@map("salary_slips")
}

// ─── Visit Management ────────────────────────────────────────────────────────

enum VisitCategory {
  SELF
  OTHER_EMPLOYEE
  VISIT_WITH
}

enum VisitPurpose {
  CLIENT_MEETING
  SITE_INSPECTION
  PRODUCT_DEMO
  FOLLOW_UP
  SUPPORT_VISIT
  OTHER
}

enum VisitScheduleType {
  SCHEDULED
  UNSCHEDULED
}

enum VisitLocationMode {
  PHYSICAL
  VIRTUAL
}

enum VisitStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?  @unique
  isActive  Boolean  @default(true)
  visits    Visit[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

model Visit {
  id                  Int               @id @default(autoincrement())

  employeeId          Int
  employee            Employee          @relation("VisitOwner", fields: [employeeId], references: [id])

  customerId          Int
  customer            Customer          @relation(fields: [customerId], references: [id])

  visitDate           DateTime
  purpose             VisitPurpose      @default(CLIENT_MEETING)
  scheduleType        VisitScheduleType @default(SCHEDULED)
  locationMode        VisitLocationMode @default(PHYSICAL)
  category            VisitCategory     @default(SELF)

  companionEmployeeId Int?
  companionEmployee   Employee?         @relation("VisitCompanion", fields: [companionEmployeeId], references: [id])

  remarks             String?           @db.Text
  status              VisitStatus       @default(SCHEDULED)

  createdById         Int
  createdBy           Employee          @relation("VisitCreatedBy", fields: [createdById], references: [id])

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("visits")
}

// ─── Loan Management ────────────────────────────────────────────────────────────

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
  REPAID
}

model LoanRequest {
  id                  Int          @id @default(autoincrement())

  employeeId          Int
  employee            Employee     @relation(fields: [employeeId], references: [id])

  loanAmount          Decimal
  reason              String       @db.Text
  repaymentPeriod     Int          // in months

  status              LoanStatus   @default(PENDING)
  approvedAmount      Decimal?
  disbursedAmount     Decimal?
  approvedAt          DateTime?
  rejectionReason     String?
  disbursedAt         DateTime?
  repaidAt            DateTime?

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@map("loan_requests")
}
