# Environment Configuration Example
# Copy this file to .env and update with your values

PORT=5000
DATABASE_URL="file:./dev.db"
NODE_ENV="development"

# JWT secrets (required for auth)
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Comma-separated list of allowed frontend origins (no trailing slash)
# Local dev is always allowed. Add production URLs here.
# Example: CLIENT_URL=https://your-app.vercel.app,https://your-app-git-main.vercel.app
CLIENT_URL=http://localhost:5173
