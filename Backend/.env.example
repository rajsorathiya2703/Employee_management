# Environment Configuration Example
# Copy this file to .env and update with your values

PORT=5000
# TiDB Cloud MySQL — sslaccept=strict is required for public endpoints (TLS).
# Copy the connection string from TiDB Cloud Connect dialog, then append:
#   ?sslaccept=strict   (or &sslaccept=strict if the URL already has query params)
# Must start with mysql:// (TiDB Cloud) — NOT postgresql://
DATABASE_URL="mysql://user:password@gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com:4000/employee_management?sslaccept=strict"
NODE_ENV="development"

# JWT secrets (required for auth)
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Comma-separated list of allowed frontend origins (no trailing slash)
# Local dev is always allowed. Add production URLs here.
# Production (Render): comma-separated Vercel URLs, no trailing slash
# CLIENT_URL=https://employee-management-livid-rho.vercel.app
CLIENT_URL=http://localhost:5173
