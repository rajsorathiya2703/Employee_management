# Copy this file to .env for local development
# For production (Vercel), set VITE_API_URL in the Vercel dashboard under
# Project → Settings → Environment Variables

# Local development — points to your local backend
VITE_API_URL=http://localhost:5000/api

# Production — your Render BACKEND URL (must end with /api)
# DO NOT use the Render deploy hook (https://api.render.com/deploy/...)
# VITE_API_URL=https://employee-management-by-minehrsolution.onrender.com/api
